{
  "manifest_version": 3,
  "name": "Controle de Aula — Chromebook",
  "description": "Recebe comandos do professor (via Firebase, criptografia ponta-a-ponta) e controla o Chromebook: abre/fecha URLs, bloqueia sites da aula e informa as abas abertas (sem captura de tela).",
  "version": "0.4.0",
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_title": "Controle de Aula",
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "permissions": ["tabs", "storage", "offscreen", "alarms", "wallpaper"],
  "host_permissions": [
    "https://*.firebaseio.com/*",
    "https://*.firebasedatabase.app/*",
    "https://identitytoolkit.googleapis.com/*",
    "https://securetoken.googleapis.com/*"
  ],
  "minimum_chrome_version": "133"
}
